#include <stdio.h>

int main() {
    int num1, num2, sum;

    // Prompt user for input
    printf("Enter two integers: ");
    
    // Read the integers and store them in memory addresses
    scanf("%d %d", &num1, &num2);

    // Calculate the sum using the '+' operator
    sum = num1 + num2;

    // Display the final output
    printf("%d + %d = %d\n", num1, num2, sum);

    return 0;
}
